DATA_PROVIDER=supabase

# 서버에서 사용할 Supabase 엔드포인트
SUPABASE_URL=https://oapnvqwhektsjgzqexzi.supabase.co

# 관리자 API에서는 service_role 사용 권장 (RLS 영향 최소화)
SUPABASE_SERVICE_ROLE_KEY=...

# service_role 미사용 시 anon 키 대체 가능
SUPABASE_ANON_KEY=...

SUPABASE_CUSTOMERS_TABLE=customers
SUPABASE_TRAFFIC_TABLE=traffic_events

# Admin auth JWT secret (32+ chars recommended)
AUTH_JWT_SECRET=replace-with-long-random-secret
